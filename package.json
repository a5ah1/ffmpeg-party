    "@11ty/eleventy": "^3.1.2",
    "@tailwindcss/postcss": "^4.1.16",
    "cssnano": "^7.1.1",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.16"
  },
  "dependencies": {
    "headroom.js": "^0.12.0"
  }
}
