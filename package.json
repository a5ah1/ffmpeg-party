  "main": "index.js",
  "scripts": {
    "clean": "rimraf _site src/css/output.css",
    "build:css": "postcss src/css/styles.css -o src/css/output.css --minify",
    "watch:css": "postcss src/css/styles.css -o src/css/output.css --watch",
    "start": "npm run watch:css & npx @11ty/eleventy --serve",
