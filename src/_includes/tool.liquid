---
layout: base.liquid
---

<div class="page-head">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">~/</a><span class="sep">/</span><a href="/#tools">tools</a><span class="sep">/</span><span class="cur">{{ page.fileSlug }}</span>
  </nav>
  <div style="font-family: var(--fs-mono); font-size: 11px; color: var(--teal); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 14px;">
    [ TOOL · {{ toolNumber | default: "T" }} ]
  </div>
  <h1 class="page-title">{{ title }}</h1>
  {% if description %}<p class="page-sub">{{ description }}</p>{% endif %}
</div>

{{ content }}

{% if useFormGenerator %}
<script src="/js/form-generator.js?v={{ build.timestamp }}"></script>
{% endif %}
{% if toolScript %}
<script src="/js/{{ toolScript }}?v={{ build.timestamp }}"></script>
{% endif %}
