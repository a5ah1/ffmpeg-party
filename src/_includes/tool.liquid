---
layout: base.liquid
---

<article class="max-w-6xl mx-auto px-4 py-12">
  <!-- Tool Header -->
  <header class="mb-8">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-3">
      {{ title }}
    </h1>
    {% if description %}
    <p class="text-xl text-zinc-400">
      {{ description }}
    </p>
    {% endif %}
  </header>

  <!-- Safety Admonition -->
  <div class="ffmpeg-admonition">
    <svg
      class="ffmpeg-admonition-icon w-5 h-5"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="10" />
      <path d="M12 16v-4" />
      <path d="M12 8h.01" />
    </svg>
    <p>
      Always exercise caution when copying and executing commands from the internet.
    </p>
  </div>

  <!-- Tool Content (Form and Output) -->
  <main class="mb-12">
    {{ content }}
  </main>

  <!-- About Section -->
  {% if aboutContent %}
  <aside class="ffmpeg-about">
    <h2>About</h2>
    <div class="about-content">
      {{ aboutContent }}
    </div>
  </aside>
  {% endif %}
</article>

<!-- Load shared form utilities if specified -->
{% if useFormGenerator %}
<script src="/js/form-generator.js?v={{ build.timestamp }}"></script>
{% endif %}

<!-- Load tool-specific JavaScript if specified -->
{% if toolScript %}
<script src="/js/{{ toolScript }}?v={{ build.timestamp }}"></script>
{% endif %}
