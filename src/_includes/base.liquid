<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="dark">

  <!-- Canonical URL -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Favicons & Icons -->
  <link rel="icon" type="image/png" href="/icons/favicon-96x96.png" sizes="96x96">
  <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  {%- comment -%}
  Meta variables: Use page frontmatter if available, otherwise fall back to site defaults
  {%- endcomment -%}
  {%- assign metaTitle = title | default: site.title -%}
  {%- assign metaDescription = description | default: site.description -%}
  {%- assign metaImage = image | default: site.image -%}
  {%- assign metaUrl = site.url | append: page.url -%}
  {%- if metaImage -%}
    {%- assign metaImageUrl = site.url | append: metaImage -%}
    {%- assign twitterCardType = "summary_large_image" -%}
  {%- else -%}
    {%- assign twitterCardType = "summary" -%}
  {%- endif -%}

  <title>{{ metaTitle }}</title>

  <!-- SEO Meta Tags -->
  <meta name="description" content="{{ metaDescription }}">
  <meta name="keywords" content="ffmpeg, video encoding, webm, av1, x264, x265, vp9, command generator, video converter">
  <meta name="author" content="{{ site.name }}">

  <!-- Open Graph / Social Media Meta Tags -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ metaUrl }}">
  <meta property="og:title" content="{{ metaTitle }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:site_name" content="{{ site.name }}">
  {%- if metaImage -%}
  <meta property="og:image" content="{{ metaImageUrl }}">
  <meta property="og:image:width" content="{{ site.imageWidth }}">
  <meta property="og:image:height" content="{{ site.imageHeight }}">
  {%- endif -%}

  <!-- Twitter Card Meta Tags -->
  <meta name="twitter:card" content="{{ twitterCardType }}">
  <meta name="twitter:title" content="{{ metaTitle }}">
  <meta name="twitter:description" content="{{ metaDescription }}">
  {%- if metaImage -%}
  <meta name="twitter:image" content="{{ metaImageUrl }}">
  {%- endif -%}

  <link rel="stylesheet" href="/css/output.css?v={{ build.timestamp }}">
</head>
<body class="bg-zinc-900 text-zinc-100 min-h-screen">
  <!-- Desktop Navigation Bar -->
  <nav class="bg-zinc-800 border-b border-zinc-700 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo/Brand -->
        <div class="flex-shrink-0">
          <a href="/" class="font-bold text-teal-400 hover:text-teal-300 transition-colors">
            ffmpeg.party
          </a>
        </div>

        <!-- Desktop Menu -->
        <div class="hidden md:flex items-center space-x-1">
          <!-- Tools Dropdown -->
          <div class="relative dropdown">
            <button
              class="text-zinc-300 hover:text-teal-400 transition-colors px-3 py-2 rounded-md flex items-center gap-1 dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Tools
              <svg class="w-4 h-4 transition-transform dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="dropdown-menu absolute left-0 top-full w-64 bg-zinc-800 border border-zinc-700 rounded-md shadow-xl opacity-0 invisible transition-all duration-200 z-50">
              <div class="py-2">
                <a href="/tools/vp9-wizard/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  VP9 Wizard
                </a>
                <a href="/tools/av1-wizard/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  AV1 Wizard
                </a>
                <a href="/tools/x264-wizard/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  x264 Wizard
                </a>
                <a href="/tools/x265-wizard/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  x265 Wizard
                </a>
                <div class="border-t border-zinc-700 my-2"></div>
                <a href="/tools/cropper/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  Cropper
                </a>
                <a href="/tools/anamorphic-crop/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  Anamorphic Crop Tool
                </a>
                <a href="/tools/frame-interpolation/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  Frame Interpolation
                </a>
                <div class="border-t border-zinc-700 my-2"></div>
                <a href="/tools/duration-calculator/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  Duration Calculator
                </a>
                <a href="/tools/webm-from-image-sequence/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors text-sm">
                  WebM from Image Sequence <span class="text-zinc-500">(Legacy)</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Guides Dropdown -->
          <div class="relative dropdown">
            <button
              class="text-zinc-300 hover:text-teal-400 transition-colors px-3 py-2 rounded-md flex items-center gap-1 dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Guides
              <svg class="w-4 h-4 transition-transform dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="dropdown-menu absolute left-0 top-full w-56 bg-zinc-800 border border-zinc-700 rounded-md shadow-xl opacity-0 invisible transition-all duration-200 z-50">
              <div class="py-2">
                <a href="/guides/x264/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  x264 Encoder Guide
                </a>
                <a href="/guides/x265/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  x265 Encoder Guide
                </a>
                <a href="/guides/av1/" class="block px-4 py-2 text-zinc-300 hover:bg-zinc-700 hover:text-teal-400 transition-colors">
                  AV1 Encoder Guide
                </a>
              </div>
            </div>
          </div>

          <a href="/resources/" class="text-zinc-300 hover:text-teal-400 transition-colors px-3 py-2 rounded-md">
            Resources
          </a>

          <a href="/blog/" class="text-zinc-300 hover:text-teal-400 transition-colors px-3 py-2 rounded-md">
            Blog
          </a>

          <a href="/about/" class="text-zinc-300 hover:text-teal-400 transition-colors px-3 py-2 rounded-md">
            About
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="md:hidden text-zinc-300 hover:text-teal-400 focus:outline-none focus:ring-2 focus:ring-teal-500 rounded p-2"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Navigation Overlay -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden"
    aria-hidden="true"
  ></div>

  <!-- Mobile Navigation Sidebar -->
  <div
    id="mobile-menu"
    class="fixed top-0 right-0 h-full w-64 bg-zinc-800 shadow-xl transform translate-x-full transition-transform duration-300 ease-in-out z-50"
    role="navigation"
  >
    <div class="flex flex-col h-full">
      <!-- Close Button -->
      <div class="flex justify-end p-4 border-b border-zinc-700">
        <button
          id="mobile-menu-close"
          class="text-zinc-300 hover:text-teal-400 focus:outline-none focus:ring-2 focus:ring-teal-500 rounded p-2"
          aria-label="Close menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu Items -->
      <nav class="flex-1 px-4 py-6 overflow-y-auto">
        <!-- Tools Accordion -->
        <div class="mobile-accordion mb-2">
          <button class="mobile-accordion-trigger w-full text-left text-zinc-300 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-3 rounded flex items-center justify-between">
            <span>Tools</span>
            <svg class="w-5 h-5 transition-transform mobile-accordion-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="mobile-accordion-content max-h-0 overflow-hidden transition-all duration-300">
            <div class="pl-4 pt-2 space-y-1">
              <a href="/tools/vp9-wizard/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                VP9 Wizard
              </a>
              <a href="/tools/av1-wizard/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                AV1 Wizard
              </a>
              <a href="/tools/x264-wizard/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                x264 Wizard
              </a>
              <a href="/tools/x265-wizard/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                x265 Wizard
              </a>
              <div class="border-t border-zinc-700 my-2 mx-4"></div>
              <a href="/tools/cropper/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                Cropper
              </a>
              <a href="/tools/anamorphic-crop/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                Anamorphic Crop Tool
              </a>
              <a href="/tools/frame-interpolation/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                Frame Interpolation
              </a>
              <div class="border-t border-zinc-700 my-2 mx-4"></div>
              <a href="/tools/duration-calculator/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                Duration Calculator
              </a>
              <a href="/tools/webm-from-image-sequence/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                WebM from Image Sequence <span class="text-zinc-500 text-xs">(Legacy)</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Guides Accordion -->
        <div class="mobile-accordion mb-2">
          <button class="mobile-accordion-trigger w-full text-left text-zinc-300 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-3 rounded flex items-center justify-between">
            <span>Guides</span>
            <svg class="w-5 h-5 transition-transform mobile-accordion-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="mobile-accordion-content max-h-0 overflow-hidden transition-all duration-300">
            <div class="pl-4 pt-2 space-y-1">
              <a href="/guides/x264/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                x264 Encoder Guide
              </a>
              <a href="/guides/x265/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                x265 Encoder Guide
              </a>
              <a href="/guides/av1/" class="block text-zinc-400 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-2 rounded text-sm">
                AV1 Encoder Guide
              </a>
            </div>
          </div>
        </div>

        <a href="/resources/" class="block text-zinc-300 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-3 rounded mb-2">
          Resources
        </a>

        <a href="/blog/" class="block text-zinc-300 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-3 rounded mb-2">
          Blog
        </a>

        <a href="/about/" class="block text-zinc-300 hover:text-teal-400 hover:bg-zinc-700/50 transition-all px-4 py-3 rounded">
          About
        </a>
      </nav>
    </div>
  </div>

  <!-- Main Content -->
  <main>
    {{ content }}
  </main>

  <!-- Footer -->
  <footer class="bg-zinc-800 border-t border-zinc-700 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <!-- Left Column: Site Info & License -->
        <div>
          <h3 class="text-white font-semibold mb-3">ffmpeg.party</h3>
          <p class="text-zinc-400 text-sm mb-4">
            Interactive FFmpeg command generators and guides
          </p>
          <div class="text-sm text-zinc-400 mb-4">
            <p class="mb-2">
              Code: <a href="https://opensource.org/licenses/MIT" class="text-teal-400 hover:text-teal-300 underline" target="_blank" rel="noopener">MIT License</a>
            </p>
            <p>
              Content: <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" class="text-teal-400 hover:text-teal-300 underline" target="_blank" rel="noopener">CC BY-NC-SA 4.0</a>
            </p>
          </div>
          <a href="https://github.com/a5ah1/ffmpeg-party" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-zinc-300 hover:text-teal-400 transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github-icon lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            View on GitHub
          </a>
        </div>

        <!-- Right Column: Navigation -->
        <div>
          <h3 class="text-white font-semibold mb-3">Navigation</h3>
          <nav class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm">
            <a href="/" class="text-zinc-400 hover:text-teal-400 transition-colors">Home</a>
            <a href="/blog/" class="text-zinc-400 hover:text-teal-400 transition-colors">Blog</a>
            <a href="/about/" class="text-zinc-400 hover:text-teal-400 transition-colors">About</a>
            <a href="/privacy/" class="text-zinc-400 hover:text-teal-400 transition-colors">Privacy</a>
            <a href="/resources/" class="text-zinc-400 hover:text-teal-400 transition-colors">Resources</a>
          </nav>
        </div>
      </div>

      <!-- Bottom Row -->
      <div class="pt-8 border-t border-zinc-700">
        <p class="text-center text-zinc-500 text-sm">
          ffmpeg.party is not affiliated with the FFmpeg project. FFmpeg is a trademark of Fabrice Bellard.
        </p>
      </div>
    </div>
  </footer>

  <!-- Headroom.js CDN -->
  <script src="https://unpkg.com/headroom.js@0.12.0/dist/headroom.min.js"></script>

  <!-- Navigation JavaScript -->
  <script src="/js/navigation.js?v={{ build.timestamp }}"></script>
  <script src="/js/headroom-init.js?v={{ build.timestamp }}"></script>
</body>
</html>
