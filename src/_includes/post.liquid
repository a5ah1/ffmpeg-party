---
layout: base.liquid
---

<article class="max-w-3xl mx-auto px-4 py-12">
  <!-- Post Header -->
  <header class="mb-8">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
      {{ title }}
    </h1>
    <div class="flex items-center gap-4 text-zinc-400">
      <time datetime="{{ date | date: '%Y-%m-%d' }}" class="text-teal-400">
        {{ date | date: "%B %d, %Y" }}
      </time>
      {% if author %}
      <span>by {{ author }}</span>
      {% endif %}
    </div>
  </header>

  <!-- Post Content -->
  <div class="prose">
    {{ content }}
  </div>

  <!-- Back to Blog Link -->
  <footer class="mt-12 pt-8 border-t border-zinc-700">
    <a href="/blog/" class="text-teal-400 hover:text-teal-300 transition-colors">
      ← Back to Blog
    </a>
  </footer>
</article>
