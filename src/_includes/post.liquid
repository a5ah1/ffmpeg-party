---
layout: base.liquid
---

<div class="page-head">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">~/</a><span class="sep">/</span><a href="/blog/">blog</a><span class="sep">/</span><span class="cur">{{ page.fileSlug }}</span>
  </nav>
  <div class="page-head__eyebrow">[ POST · {{ date | date: "%Y-%m-%d" }} ]</div>
  <h1 class="page-title">{{ title }}</h1>
  {% if description %}
    <p class="page-sub">{{ description }}</p>
  {% endif %}
</div>

<div class="guide-layout">
  <div></div>
  <article class="guide-prose">
    {{ content }}
    <div class="post-back">
      <a href="/blog/">← back to blog</a>
    </div>
  </article>
  <aside class="aside" aria-label="Post meta">
    <h4>posted</h4>
    <div class="aside__value">{{ date | date: "%B %-d, %Y" }}</div>
    {% if author %}
      <div class="divider"></div>
      <h4>by</h4>
      <div class="aside__value">{{ author }}</div>
    {% endif %}
    <div class="divider"></div>
    <h4>elsewhere</h4>
    <ul>
      <li><a href="/blog/">→ all posts</a></li>
      <li><a href="/">→ home</a></li>
    </ul>
  </aside>
</div>
