---
layout: base.liquid
---

<div class="page-head">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">~/</a><span class="sep">/</span><a href="/#guides">guides</a><span class="sep">/</span><span class="cur">{{ page.fileSlug }}</span>
  </nav>
  <div class="page-head__eyebrow">[ GUIDE · {{ guideNumber | default: "G" }} ]</div>
  <h1 class="page-title">{{ title }}</h1>
  {% if description %}
    <p class="page-sub">{{ description }}</p>
  {% endif %}
</div>

<div class="guide-layout">
  <aside class="toc" aria-label="Contents">
    <div class="toc__label">contents</div>
    <div data-toc-target></div>
  </aside>

  <article class="guide-prose">
    {{ content }}
  </article>

  <aside class="aside" aria-label="Related">
    <h4>other guides</h4>
    <ul>
      {%- assign here = page.fileSlug -%}
      {%- if here != "x264" -%}<li><a href="/guides/x264/">→ x264 encoder</a></li>{%- endif -%}
      {%- if here != "x265" -%}<li><a href="/guides/x265/">→ x265 / HEVC</a></li>{%- endif -%}
      {%- if here != "av1" -%}<li><a href="/guides/av1/">→ AV1 / SVT-AV1</a></li>{%- endif -%}
      {%- if here != "ai-video-loop" -%}<li><a href="/guides/ai-video-loop/">→ AI video loops</a></li>{%- endif -%}
    </ul>
    {% if relatedTool %}
      <div class="divider"></div>
      <h4>related tool</h4>
      <ul>
        <li><a href="{{ relatedTool.href }}">→ {{ relatedTool.name }}</a></li>
      </ul>
    {% endif %}
    <div class="divider"></div>
    <h4>elsewhere</h4>
    <ul>
      <li><a href="/resources/">→ resources</a></li>
      <li><a href="/">→ home</a></li>
    </ul>
  </aside>
</div>

<script src="/js/guide.js?v={{ build.timestamp }}"></script>
{% if useFormGenerator %}
<script src="/js/form-generator.js?v={{ build.timestamp }}"></script>
{% endif %}
{% if guideScript %}
<script src="/js/{{ guideScript }}?v={{ build.timestamp }}"></script>
{% endif %}
