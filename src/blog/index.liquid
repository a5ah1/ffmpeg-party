---
layout: page.liquid
title: Blog - ffmpeg.party
description: Latest updates, tips, and news from ffmpeg.party
permalink: /blog/
tags: []
eleventyExcludeFromCollections: true
---

<div class="max-w-4xl mx-auto">
  {% assign posts = collections.post | reverse %}

  {% if posts.size > 0 %}
    <div class="space-y-8">
      {% for post in posts %}
        <article class="bg-zinc-800 border border-zinc-700 rounded-lg p-6 hover:border-teal-500 transition-all">
          <h2 class="text-2xl font-bold text-white mb-2">
            <a href="{{ post.url }}" class="hover:text-teal-400 transition-colors">
              {{ post.data.title }}
            </a>
          </h2>
          <time datetime="{{ post.date | date: '%Y-%m-%d' }}" class="text-sm text-teal-400 mb-3 block">
            {{ post.date | date: "%B %d, %Y" }}
          </time>
          {% if post.data.description %}
            <p class="text-zinc-400">
              {{ post.data.description }}
            </p>
          {% endif %}
          <a href="{{ post.url }}" class="inline-block mt-4 text-teal-400 hover:text-teal-300 transition-colors">
            Read more →
          </a>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-zinc-400">No posts yet. Check back soon!</p>
  {% endif %}
</div>
