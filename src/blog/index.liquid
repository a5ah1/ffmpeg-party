---
layout: base.liquid
title: Blog — ffmpeg.party
description: Latest updates, tips, and notes from ffmpeg.party
permalink: /blog/
tags: []
eleventyExcludeFromCollections: true
---

<div class="page-head">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">~/</a><span class="sep">/</span><span class="cur">blog</span>
  </nav>
  <h1 class="page-title"><span class="accent">$</span> tail -f /blog</h1>
  <p class="page-sub">Updates, encoding notes, and occasional half-baked thoughts.</p>
</div>

<div class="blog-layout">
  {% assign posts = collections.post | reverse %}

  {% if posts.size == 0 %}
    <p style="font-family: var(--fs-mono); color: var(--ink-2);">$ ls /blog → no posts yet. check back soon.</p>
  {% else %}
    {% assign featured = posts | first %}

    <a class="blog-featured" href="{{ featured.url }}">
      <div class="blog-featured__tag">[ FEATURED · {{ featured.date | date: "%Y-%m-%d" }} ]</div>
      <h2 class="blog-featured__title">{{ featured.data.title }}</h2>
      {% if featured.data.description %}
        <p class="blog-featured__excerpt">{{ featured.data.description }}</p>
      {% endif %}
      <div class="blog-featured__meta">
        <span>read →</span>
      </div>
    </a>

    {% if posts.size > 1 %}
      <div class="bloglist">
        {% for post in posts offset: 1 %}
          <a class="blogrow" href="{{ post.url }}">
            <div class="blogrow__date">
              <b>{{ post.date | date: "%d" }}</b>
              <span>{{ post.date | date: "%b %Y" }}</span>
            </div>
            <div class="blogrow__body">
              <div class="blogrow__head">
                <span class="blogrow__tag">post</span>
                <span>{{ post.date | date: "%Y-%m-%d" }}</span>
              </div>
              <div class="blogrow__title">{{ post.data.title }}</div>
              {% if post.data.description %}
                <div class="blogrow__excerpt">{{ post.data.description }}</div>
              {% endif %}
            </div>
            <div class="blogrow__arrow">→</div>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
</div>
